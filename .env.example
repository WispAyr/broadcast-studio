# Broadcast Studio Configuration
JWT_SECRET=change-me-in-production
PORT=3945
NODE_ENV=production

# ── Nuro ecosystem integration (optional) ────────────────────────────────────
# Leave blank to run the studio in standalone mode without Nuro.
# Set these to connect to the local Nuro mesh network.
NURO_HUB_URL=http://192.168.x.x:3960
NURO_DISPATCH_URL=http://192.168.x.x:3961
NURO_SERVICE_TOKEN=your-shared-secret-here
